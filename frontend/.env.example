# Backend API URL — set this to your Render service URL in production
# Leave blank in dev (Vite proxy handles /api -> localhost:8000)
VITE_API_URL=https://nutrition-label-api.onrender.com/api

# Base path for GitHub Pages (set to /Nutrition-Label/ in CI, leave blank for Vercel/Netlify)
VITE_BASE_PATH=/Nutrition-Label/
